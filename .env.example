# Copy to .env (gitignored) to enable the optional Claude semantic classifier (--llm).
# The default deterministic scan and the test-suite need NONE of these.

# Your Anthropic API key — https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Optional: override the model used by the --llm classifier.
SKILLSENTRY_MODEL=claude-haiku-4-5
